{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://litemiro.dev/schemas/ontology_b.schema.json",
  "title": "OntologyB",
  "description": "Phase 1 → Phase 2 memory contract. Per-agent memory stores + runtime config.",
  "type": "object",
  "required": ["version", "config", "stores"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "episodic_max": { "type": "integer", "minimum": 1 },
        "semantic_max": { "type": "integer", "minimum": 1 },
        "episodic_decay_rate": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "semantic_decay_rate": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "retrieval_max": { "type": "integer", "minimum": 1 },
        "token_budget_per_agent": { "type": "integer", "minimum": 1 }
      }
    },
    "stores": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["agent_id"],
        "additionalProperties": false,
        "properties": {
          "agent_id": { "type": "string", "minLength": 1 },
          "episodic": { "type": "array" },
          "semantic": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "summary"],
              "additionalProperties": false,
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "summary": { "type": "string" },
                "topics": { "type": "array", "items": { "type": "string" } },
                "dominant_sentiment": { "type": "string" },
                "key_relationships": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["agent_id", "nature"],
                    "additionalProperties": false,
                    "properties": {
                      "agent_id": { "type": "string", "minLength": 1 },
                      "nature": { "type": "string" }
                    }
                  }
                },
                "simulation_count": { "type": "integer", "minimum": 0 },
                "last_relevant_sim": { "type": "integer", "minimum": 0 }
              }
            }
          }
        }
      }
    }
  }
}
